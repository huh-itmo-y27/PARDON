              "type": "integer",
              "maximum": 200,
              "minimum": 1,
              "default": 50,
              "title": "Limit"
            }
          },
          {
            "name": "only_unread",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
