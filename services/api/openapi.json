  "components": {
    "schemas": {
      "DriftNotification": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "severity": {
            "type": "string",
            "title": "Severity"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "read": {
            "type": "boolean",
            "title": "Read"
          }
        },
        "type": "object",
        "required": [
          "id",
          "created_at",
          "severity",
          "title",
          "message",
          "read"
        ],
        "title": "DriftNotification"
      },
      "ExperimentItem": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id"
          },
          "experiment": {
            "type": "string",
            "title": "Experiment"
          },
          "model_name": {
            "type": "string",
            "title": "Model Name"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "metrics": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Metrics"
          },
          "params": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Params"
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "experiment",
          "model_name",
          "status",
          "started_at",
          "metrics",
          "params"
        ],
        "title": "ExperimentItem"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PredictRecord": {
        "properties": {
          "source_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Id"
          },
          "features": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Features"
          }
        },
        "type": "object",
        "title": "PredictRecord"
      },
      "PredictRequest": {
        "properties": {
          "model_name": {
            "type": "string",
            "title": "Model Name",
            "default": "isolation_forest"
          },
          "records": {
            "items": {
              "$ref": "#/components/schemas/PredictRecord"
            },
            "type": "array",
            "minItems": 1,
            "title": "Records"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id"
          }
        },
        "type": "object",
        "required": [
          "records"
        ],
        "title": "PredictRequest"
      },
      "PredictResponse": {
        "properties": {
          "request_id": {
            "type": "string",
            "title": "Request Id"
          },
          "model_name": {
            "type": "string",
            "title": "Model Name"
          },
          "predictions": {
            "items": {
              "$ref": "#/components/schemas/PredictionItem"
            },
            "type": "array",
            "title": "Predictions"
          },
          "drift": {
            "additionalProperties": true,
            "type": "object",
            "title": "Drift"
          }
        },
        "type": "object",
        "required": [
          "request_id",
          "model_name",
          "predictions",
          "drift"
        ],
        "title": "PredictResponse"
      },
      "PredictionItem": {
        "properties": {
          "source_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Id"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "threshold": {
            "type": "number",
            "title": "Threshold"
          },
          "anomaly_flag": {
            "type": "integer",
            "title": "Anomaly Flag"
          }
        },
        "type": "object",
        "required": [
          "source_id",
          "score",
          "threshold",
          "anomaly_flag"
        ],
        "title": "PredictionItem"
      },
      "RecentPrediction": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id"
          },
          "source_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Id"
          },
          "model_name": {
            "type": "string",
            "title": "Model Name"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "threshold": {
            "type": "number",
            "title": "Threshold"
          },
          "anomaly_flag": {
            "type": "integer",
            "title": "Anomaly Flag"
          }
        },
        "type": "object",
        "required": [
          "id",
          "created_at",
          "request_id",
          "source_id",
          "model_name",
          "score",
          "threshold",
          "anomaly_flag"
        ],
        "title": "RecentPrediction"
      },
      "RetrainJobResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "model_name": {
            "type": "string",
            "title": "Model Name"
          },
          "dataset_scenario": {
            "type": "string",
            "title": "Dataset Scenario"
          },
          "details": {
            "additionalProperties": true,
            "type": "object",
            "title": "Details"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status",
          "model_name",
          "dataset_scenario",
          "details"
        ],
        "title": "RetrainJobResponse"
      },
      "RetrainRequest": {
        "properties": {
          "model_name": {
            "type": "string",
            "title": "Model Name",
            "default": "isolation_forest"
          },
          "dataset_scenario": {
            "type": "string",
            "title": "Dataset Scenario",
            "default": "all"
          },
          "register_model": {
            "type": "boolean",
            "title": "Register Model",
            "default": true
          }
        },
        "type": "object",
        "title": "RetrainRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}