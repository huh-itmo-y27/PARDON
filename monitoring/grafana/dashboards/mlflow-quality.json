{
  "id": null,
  "uid": "mlflow-quality",
  "title": "MLflow Quality: Current vs History",
  "tags": ["anomaly", "mlflow"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Train Runs Total",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
      "targets": [{"expr": "mlflow_train_runs_total", "legendFormat": "train {{model_name}} {{dataset_scenario}}"}]
    },
    {
      "type": "stat",
      "title": "Inference Runs Total",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 4},
      "targets": [{"expr": "mlflow_infer_runs_total", "legendFormat": "infer {{model_name}} {{dataset_scenario}}"}]
    },
    {
      "type": "stat",
      "title": "Current Val F1",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 8},
      "targets": [{"expr": "mlflow_train_metric_value{metric=\"val_f1\",aggregation=\"latest\"}", "legendFormat": "{{model_name}} {{dataset_scenario}} latest"}]
    },
    {
      "type": "stat",
      "title": "Val F1 vs Previous Mean",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 12},
      "targets": [{"expr": "mlflow_train_metric_value{metric=\"val_f1\",aggregation=\"delta_vs_previous_mean\"}", "legendFormat": "{{model_name}} {{dataset_scenario}} delta"}]
    },
    {
      "type": "timeseries",
      "title": "Train Val F1 Current vs Mean/Best",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {"expr": "mlflow_train_metric_value{metric=\"val_f1\",aggregation=~\"latest|previous_mean|rolling_mean_5|best\"}", "legendFormat": "val_f1 {{aggregation}} {{model_name}} {{dataset_scenario}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Train Val CP F1 Current vs Mean/Best",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "targets": [
        {"expr": "mlflow_train_metric_value{metric=\"val_cp_f1\",aggregation=~\"latest|previous_mean|rolling_mean_5|best\"}", "legendFormat": "val_cp_f1 {{aggregation}} {{model_name}} {{dataset_scenario}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Train Val NAB Standard Current vs Mean/Best",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 32},
      "targets": [
        {"expr": "mlflow_train_metric_value{metric=\"val_nab_standard\",aggregation=~\"latest|previous_mean|rolling_mean_5|best\"}", "legendFormat": "val_nab_standard {{aggregation}} {{model_name}} {{dataset_scenario}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Inference Anomaly Rate Current vs Mean/Best",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40},
      "targets": [
        {"expr": "mlflow_infer_metric_value{metric=\"anomaly_rate\",aggregation=~\"latest|previous_mean|rolling_mean_5|best\"}", "legendFormat": "anomaly_rate {{aggregation}} {{model_name}} {{dataset_scenario}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Inference Avg Score Current vs Mean/Best",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 48},
      "targets": [
        {"expr": "mlflow_infer_metric_value{metric=\"avg_score\",aggregation=~\"latest|previous_mean|rolling_mean_5|best\"}", "legendFormat": "avg_score {{aggregation}} {{model_name}} {{dataset_scenario}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Train Data Drift Score Current vs Mean/Best",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 56},
      "targets": [
        {"expr": "mlflow_train_metric_value{metric=\"train_data_drift_score\",aggregation=~\"latest|previous_mean|rolling_mean_5|all_mean|best\"}", "legendFormat": "train_data_drift_score {{aggregation}} {{model_name}} {{dataset_scenario}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Train Target Drift Score Current vs Mean/Best",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 64},
      "targets": [
        {"expr": "mlflow_train_metric_value{metric=\"train_target_drift_score\",aggregation=~\"latest|previous_mean|rolling_mean_5|all_mean|best\"}", "legendFormat": "train_target_drift_score {{aggregation}} {{model_name}} {{dataset_scenario}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Train Concept Drift Proxy Current vs Mean/Best",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 72},
      "targets": [
        {"expr": "mlflow_train_metric_value{metric=\"train_concept_drift_proxy_score\",aggregation=~\"latest|previous_mean|rolling_mean_5|all_mean|best\"}", "legendFormat": "train_concept_drift_proxy_score {{aggregation}} {{model_name}} {{dataset_scenario}}"}
      ]
    }
  ]
}
